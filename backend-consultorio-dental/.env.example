# Copia este archivo como .env y ajusta los valores
# cp .env.example .env

# Prisma usa esta URL para conectarse a la base de datos.
# • Dentro de Docker: el host es "sqlserver" (nombre del servicio en docker-compose.yml)
# • En local sin Docker: usa "localhost" o la IP de tu servidor
DATABASE_URL="postgresql://tu_user:123@localhost:5432/tu_db"

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tu_db
DATABASE_USER=tu_user
DATABASE_PASSWORD=123

ON_PRODUCTION=false

JWT_SECRET=

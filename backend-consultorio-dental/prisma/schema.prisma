generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  lastname   String
  email      String   @unique
  password   String
  phone      String?
  created_at DateTime @default(now())
  role_id    Int
  status     Boolean  @default(true)

  notifications Notification[]
  patient       Patient?
  role          Role           @relation(fields: [role_id], references: [id])

  @@map("users")
}

model Role {
  id   Int    @id @default(autoincrement())
  role String @unique

  users User[]

  @@map("roles")
}

model Patient {
  id              Int      @id @default(autoincrement())
  address         String
  birth_date      DateTime
  emergency_phone String?
  user_id         Int      @unique

  appointments Appointment[]
  user         User          @relation(fields: [user_id], references: [id])

  @@map("patients")
}

model Service {
  id              Int     @id @default(autoincrement())
  name            String
  durationMinutes Int
  price           Decimal @db.Decimal(10, 2)
  description     String
  status          Boolean @default(true)

  appointments Appointment[]
  images       ServiceImage[]
  offers       ServiceOffer[]

  @@map("services")
}

model ServiceImage {
  id         Int     @id @default(autoincrement())
  url        String
  location  String?
  service_id Int

  service Service @relation(fields: [service_id], references: [id])

  @@map("services_images")
}

enum AppointmentStatus {
  PENDIENTE
  COMPLETADA
  CANCELADA
  REPROGRAMADA
  CONFIRMADA
}

model Appointment {
  id              Int      @id @default(autoincrement())
  date            DateTime
  time            String
  durationMinutes Int
  status          AppointmentStatus   @default(PENDIENTE)
  notes           String
  reason          String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  patient_id      Int
  service_id      Int

  patient       Patient        @relation(fields: [patient_id], references: [id])
  service       Service        @relation(fields: [service_id], references: [id])
  consultation  Consultation?
  notifications Notification[]

  @@map("appointments")
}

model Consultation {
  id             Int      @id @default(autoincrement())
  notes          String
  observations   String
  created_at     DateTime @default(now())
  appointment_id Int      @unique

  appointment Appointment           @relation(fields: [appointment_id], references: [id])
  images      ConsultationImage[]

  @@map("consultations")
}

model ConsultationImage {
  id              Int     @id @default(autoincrement())
  url             String
  location        String?
  consultation_id Int

  consultation Consultation @relation(fields: [consultation_id], references: [id])

  @@map("consultations_images")
}

model Offer {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  start_date  DateTime
  end_date    DateTime
  status      Boolean  @default(false)

  services ServiceOffer[]

  @@map("offers")
}

model ServiceOffer {
  offer_id   Int
  service_id Int

  offer   Offer   @relation(fields: [offer_id], references: [id])
  service Service @relation(fields: [service_id], references: [id])

  @@id([offer_id, service_id])
  @@map("services_offers")
}

model AvailableTimeSlots {
  id         Int     @id @default(autoincrement())
  week_day   Int
  start_time String
  end_time   String
  status     Boolean

  @@map("available_time_slots")
}

model UnavailableTimeSlots {
  id     Int      @id @default(autoincrement())
  date   DateTime
  reason String

  @@map("unavailable_time_slots")
}

model FrequentlyAskedQuestion {
  id       Int    @id @default(autoincrement())
  question String
  response String

  @@map("frequently_asked_questions")
}

model Notification {
  id             Int      @id @default(autoincrement())
  type           String
  message        String
  is_read        Boolean  @default(false)
  user_id        Int
  appointment_id Int?
  created_at     DateTime @default(now())

  appointment Appointment? @relation(fields: [appointment_id], references: [id])
  user        User         @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@map("notifications")
}

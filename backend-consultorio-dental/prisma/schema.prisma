generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  lastname      String
  email         String         @unique
  password      String
  phone         String?
  created_at    DateTime       @default(now())
  rol_id        Int
  status        Boolean        @default(true)
  notifications Notificacion[]
  patient       Patient?
  rol           Rol            @relation(fields: [rol_id], references: [id])

  @@map("users")
}

model Rol {
  id       Int    @id @default(autoincrement())
  rol      String @unique
  usuarios User[]

  @@map("roles")
}

model Patient {
  id              Int      @id @default(autoincrement())
  address         String
  birth_date      DateTime
  emergency_phone String?
  user_id         Int      @unique
  appointments    Cita[]
  user            User     @relation(fields: [user_id], references: [id])

  @@map("patients")
}

model Service {
  id              Int              @id @default(autoincrement())
  name            String
  durationMinutes Int
  price           Decimal          @db.Decimal(10, 2)
  description     String
  status          Boolean          @default(true)
  appointments    Cita[]
  images          servicesImages[]
  offerts         OfertaServicio[]

  @@map("services")
}

model servicesImages {
  id         Int     @id @default(autoincrement())
  url        String
  ubication  String?
  service_id Int
  service    Service @relation(fields: [service_id], references: [id])

  @@map("services_images")
}

model Cita {
  id               Int            @id @default(autoincrement())
  fecha            DateTime
  hora             String
  duracion_minutos Int
  estado           String         @default("PENDIENTE")
  nota_previa      String
  motivo           String?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @default(now())
  paciente_id      Int
  servicio_id      Int
  paciente         Patient        @relation(fields: [paciente_id], references: [id])
  servicio         Service        @relation(fields: [servicio_id], references: [id])
  consulta         Consulta?
  notificacions    Notificacion[]

  @@map("citas")
}

model Consulta {
  id            Int                @id @default(autoincrement())
  notas         String
  observaciones String
  created_at    DateTime           @default(now())
  cita_id       Int                @unique
  cita          Cita               @relation(fields: [cita_id], references: [id])
  imagenes      ImagenesConsulta[]

  @@map("consultas")
}

model ImagenesConsulta {
  id          Int      @id @default(autoincrement())
  url         String
  ubicacion   String?
  consulta_id Int
  consulta    Consulta @relation(fields: [consulta_id], references: [id])

  @@map("imagenes_consultas")
}

model Oferta {
  id           Int              @id @default(autoincrement())
  nombre       String
  descripcion  String
  fecha_inicio DateTime
  fecha_fin    DateTime
  activa       Boolean          @default(false)
  servicios    OfertaServicio[]

  @@map("ofertas")
}

model OfertaServicio {
  id          Int     @id @default(autoincrement())
  oferta_id   Int
  servicio_id Int
  oferta      Oferta  @relation(fields: [oferta_id], references: [id])
  servicio    Service @relation(fields: [servicio_id], references: [id])

  @@map("ofertas_servicios")
}

model HorarioDisponible {
  id          Int     @id @default(autoincrement())
  dia_semana  Int
  hora_inicio String
  hora_fin    String
  estado      Boolean

  @@map("horarios_disponibles")
}

model FechaBloqueada {
  id     Int      @id @default(autoincrement())
  fecha  DateTime
  motivo String

  @@map("fechas_bloqueadas")
}

model PreguntaFrecuente {
  id        Int    @id @default(autoincrement())
  pregunta  String
  respuesta String

  @@map("preguntas_frecuentes")
}

model Notificacion {
  id         Int      @id @default(autoincrement())
  tipo       String
  mensaje    String
  leida      Boolean  @default(false)
  usuario_id Int
  cita_id    Int?
  created_at DateTime @default(now())
  cita       Cita?    @relation(fields: [cita_id], references: [id])
  usuario    User     @relation(fields: [usuario_id], references: [id], onUpdate: NoAction)

  @@map("notificaciones")
}
